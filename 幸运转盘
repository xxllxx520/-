<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🎡 幸运转盘 · 每人仅限一次</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        body {
            background: linear-gradient(145deg, #1e2b3a 0%, #0f1a24 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', Roboto, system-ui, sans-serif;
            padding: 16px;
        }
        .card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(8px);
            border-radius: 48px;
            padding: 30px 25px 35px 25px;
            box-shadow: 0 30px 50px rgba(0, 0, 0, 0.6), 0 0 0 2px rgba(255, 215, 0, 0.2) inset;
            border: 1px solid rgba(255, 240, 150, 0.3);
        }
        .wheel-container {
            position: relative;
            width: min(68vw, 480px);
            height: min(68vw, 480px);
            margin: 0 auto;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        canvas {
            width: 100% !important;
            height: 100% !important;
            display: block;
            border-radius: 50%;
            box-shadow: 0 20px 35px rgba(0, 0, 0, 0.8), 0 0 0 8px #2c3e4e, 0 0 0 12px #f1c40f;
            transition: box-shadow 0.2s;
            background: #2d3e4f;
            cursor: pointer;
        }
        canvas:active {
            transform: scale(0.99);
            transition: transform 0.1s;
        }
        .pointer {
            position: absolute;
            top: -12px;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 0;
            border-left: 28px solid transparent;
            border-right: 28px solid transparent;
            border-top: 48px solid #f2c94c;
            filter: drop-shadow(0 8px 6px rgba(0,0,0,0.5));
            z-index: 5;
            pointer-events: none;
        }
        .pointer::after {
            content: "";
            position: absolute;
            top: -52px;
            left: -12px;
            width: 24px;
            height: 24px;
            background: radial-gradient(circle at 30% 30%, #fff5b0, #e0a800);
            border-radius: 50%;
            box-shadow: 0 4px 8px black;
        }
        .info-panel {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: center;
            gap: 30px;
            margin-top: 30px;
        }
        .button-group {
            display: flex;
            gap: 18px;
            align-items: center;
        }
        .spin-btn {
            background: linear-gradient(145deg, #fedb5f, #f9b81b);
            border: none;
            color: #1e2a32;
            font-size: 1.8rem;
            font-weight: 800;
            padding: 16px 40px;
            border-radius: 60px;
            letter-spacing: 2px;
            box-shadow: 0 10px 0 #b26500, 0 12px 20px rgba(0,0,0,0.4);
            cursor: pointer;
            transition: all 0.1s cubic-bezier(0.2, 0.9, 0.3, 1.2);
            text-transform: uppercase;
            font-family: inherit;
            border: 2px solid #ffeeaa;
        }
        .spin-btn:active {
            transform: translateY(8px);
            box-shadow: 0 4px 0 #b26500, 0 12px 20px rgba(0,0,0,0.4);
        }
        .spin-btn:disabled {
            opacity: 0.5;
            transform: translateY(5px);
            box-shadow: 0 5px 0 #7a4b00, 0 8px 12px rgba(0,0,0,0.4);
            pointer-events: none;
            filter: grayscale(0.4);
        }
        .result-box {
            background: #1f2d3a;
            border-radius: 40px;
            padding: 12px 32px;
            box-shadow: inset 0 3px 8px #0b1219, 0 10px 15px rgba(0,0,0,0.5);
            border: 1px solid #ffd966;
            min-width: 180px;
            text-align: center;
        }
        .result-label {
            font-size: 1rem;
            color: #bcd0f0;
            letter-spacing: 1px;
            text-transform: uppercase;
            font-weight: 400;
        }
        .result-value {
            font-size: 2.2rem;
            font-weight: 800;
            color: #fee7a0;
            text-shadow: 0 2px 5px #ff9900;
            line-height: 1.3;
            word-break: break-word;
        }
        .footer-legend {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 12px 20px;
            margin-top: 25px;
            color: #ced8e8;
            font-weight: 600;
            background: rgba(0, 0, 0, 0.4);
            padding: 14px 20px;
            border-radius: 50px;
            backdrop-filter: blur(4px);
            border: 1px solid #ffd96655;
        }
        .legend-item {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .color-dot {
            width: 24px;
            height: 24px;
            border-radius: 24px;
            box-shadow: 0 2px 6px black;
            border: 2px solid rgba(255,255,240,0.6);
        }
    </style>
</head>
<body>
<div class="card">
    <div class="wheel-container">
        <canvas id="wheelCanvas" width="540" height="540"></canvas>
        <div class="pointer"></div>
    </div>

    <div class="info-panel">
        <div class="button-group">
            <button class="spin-btn" id="spinButton">🎲 旋转</button>
        </div>
        <div class="result-box" id="resultBox">
            <div class="result-label">本次结果</div>
            <div class="result-value" id="prizeDisplay">✨</div>
        </div>
    </div>

    <div class="footer-legend" id="legendContainer"></div>
</div>

<script>
    (function() {
        const SEGMENTS = [
            { label: '100 积分', color: '#FF6B8B' },
            { label: '谢谢参与', color: '#A0D6FF' },
            { label: '优惠券', color: '#F9E75C' },
            { label: '大奖', color: '#C56CE8' },
            { label: '500 积分', color: '#6FCF97' },
            { label: '再来一次', color: '#FFB163' },
            { label: '小礼品', color: '#B8D8F0' },
            { label: '幸运星', color: '#F3A0B6' }
        ];

        const PI = Math.PI;
        const TAU = 2 * PI;
        const segmentCount = SEGMENTS.length;
        const angleStep = TAU / segmentCount;

        let currentRotation = 0.0;
        let spinning = false;
        let animFrame = null;
        let spinVelocity = 0.0;
        const friction = 0.985;
        const minVelocity = 0.005;

        const canvas = document.getElementById('wheelCanvas');
        const ctx = canvas.getContext('2d');
        const spinBtn = document.getElementById('spinButton');
        const prizeDisplay = document.getElementById('prizeDisplay');
        const legendContainer = document.getElementById('legendContainer');

        // 本地存储键
        const STORAGE_KEY_HAS_SPUN = 'wheel_hasSpun';
        const STORAGE_KEY_ANGLE   = 'wheel_angle';
        const STORAGE_KEY_PRIZE   = 'wheel_prize';

        function saveSpinResult(angle, prizeText) {
            try {
                localStorage.setItem(STORAGE_KEY_HAS_SPUN, 'true');
                localStorage.setItem(STORAGE_KEY_ANGLE, angle.toString());
                localStorage.setItem(STORAGE_KEY_PRIZE, prizeText);
            } catch (e) {}
        }

        function loadSpinStatus() {
            const hasSpun = localStorage.getItem(STORAGE_KEY_HAS_SPUN) === 'true';
            if (!hasSpun) return { hasSpun: false };
            const angleStr = localStorage.getItem(STORAGE_KEY_ANGLE);
            const prize = localStorage.getItem(STORAGE_KEY_PRIZE) || '✨ 已参与';
            let angle = null;
            if (angleStr) {
                const parsed = parseFloat(angleStr);
                if (!isNaN(parsed)) angle = parsed;
            }
            return { hasSpun: true, angle, prize };
        }

        function drawWheel(rotateRad = currentRotation) {
            const width = canvas.width;
            const height = canvas.height;
            const centerX = width / 2;
            const centerY = height / 2;
            const radius = Math.min(width, height) * 0.42;
            ctx.clearRect(0, 0, width, height);

            ctx.shadowColor = '#000000aa';
            ctx.shadowBlur = 16;
            ctx.shadowOffsetX = 4;
            ctx.shadowOffsetY = 4;

            for (let i = 0; i < segmentCount; i++) {
                const start = i * angleStep + rotateRad;
                const end = start + angleStep;

                ctx.beginPath();
                ctx.moveTo(centerX, centerY);
                ctx.arc(centerX, centerY, radius, start, end);
                ctx.closePath();
                ctx.fillStyle = SEGMENTS[i].color;
                ctx.fill();

                ctx.save();
                ctx.shadowBlur = 8;
                ctx.shadowColor = '#ffffff40';
                ctx.strokeStyle = '#ffffff60';
                ctx.lineWidth = 1.5;
                ctx.beginPath();
                ctx.arc(centerX, centerY, radius, start, end);
                ctx.lineTo(centerX, centerY);
                ctx.stroke();
                ctx.restore();

                ctx.save();
                ctx.shadowBlur = 6;
                ctx.shadowColor = '#00000060';
                ctx.beginPath();
                ctx.moveTo(centerX, centerY);
                ctx.lineTo(centerX + Math.cos(start) * radius, centerY + Math.sin(start) * radius);
                ctx.strokeStyle = '#FFFDE7';
                ctx.lineWidth = 2.2;
                ctx.stroke();
                ctx.restore();

                ctx.save();
                ctx.translate(centerX, centerY);
                ctx.rotate(start + angleStep / 2);
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.font = 'bold 18px "Segoe UI", "Roboto", system-ui, sans-serif';
                ctx.shadowColor = '#000000aa';
                ctx.shadowBlur = 8;
                ctx.shadowOffsetX = 2;
                ctx.shadowOffsetY = 2;
                ctx.fillStyle = '#1e2a32';
                ctx.fillText(SEGMENTS[i].label, radius * 0.7, 0);
                ctx.restore();
            }

            ctx.beginPath();
            ctx.arc(centerX, centerY, radius * 0.12, 0, TAU);
            ctx.fillStyle = '#FFE484';
            ctx.shadowColor = '#f0b300';
            ctx.shadowBlur = 22;
            ctx.fill();
            ctx.shadowBlur = 10;
            ctx.strokeStyle = '#FFFFFF';
            ctx.lineWidth = 4;
            ctx.stroke();

            ctx.shadowBlur = 14;
            for (let i = 0; i < 12; i++) {
                let angle = (i / 12) * TAU + rotateRad * 0.2;
                let x = centerX + Math.cos(angle) * (radius + 12);
                let y = centerY + Math.sin(angle) * (radius + 12);
                ctx.beginPath();
                ctx.arc(x, y, 5, 0, 2 * PI);
                ctx.fillStyle = '#FFD966';
                ctx.fill();
            }
        }

        function updatePrizeFromAngle(rad) {
            let pointerAngle = (PI / 2 - rad) % TAU;
            if (pointerAngle < 0) pointerAngle += TAU;
            for (let i = 0; i < segmentCount; i++) {
                let start = i * angleStep;
                let end = start + angleStep;
                if (pointerAngle >= start && pointerAngle < end) {
                    prizeDisplay.innerText = SEGMENTS[i].label;
                    return;
                }
            }
            prizeDisplay.innerText = SEGMENTS[0].label;
        }

        function spinAnimation() {
            if (!spinning) return;
            spinVelocity *= friction;
            currentRotation = (currentRotation + spinVelocity) % TAU;
            drawWheel(currentRotation);
            updatePrizeFromAngle(currentRotation);

            if (Math.abs(spinVelocity) < minVelocity) {
                spinning = false;
                spinBtn.disabled = false;
                if (animFrame) {
                    cancelAnimationFrame(animFrame);
                    animFrame = null;
                }
                saveSpinResult(currentRotation, prizeDisplay.innerText);
                spinBtn.disabled = true;
                return;
            }
            animFrame = requestAnimationFrame(spinAnimation);
        }

        function requestSpin() {
            const status = loadSpinStatus();
            if (status.hasSpun) {
                prizeDisplay.innerText = '🎫 仅限一次';
                spinBtn.disabled = true;
                return;
            }
            if (spinning) return;

            try {
                localStorage.setItem(STORAGE_KEY_HAS_SPUN, 'true');
            } catch (e) {}

            spinning = true;
            spinBtn.disabled = true;
            spinVelocity = 0.5 + Math.random() * 0.6;
            if (Math.random() < 0.15) spinVelocity *= -1;
            if (animFrame) cancelAnimationFrame(animFrame);
            animFrame = requestAnimationFrame(spinAnimation);
        }

        function randomInitRotation() {
            currentRotation = Math.random() * angleStep;
            drawWheel(currentRotation);
            updatePrizeFromAngle(currentRotation);
        }

        function initWheelFromStorage() {
            const status = loadSpinStatus();
            if (status.hasSpun) {
                if (status.angle !== null) {
                    currentRotation = status.angle;
                    drawWheel(currentRotation);
                    updatePrizeFromAngle(currentRotation);
                    if (status.prize) prizeDisplay.innerText = status.prize;
                } else {
                    randomInitRotation();
                    prizeDisplay.innerText = '🎫 已参与';
                }
                spinBtn.disabled = true;
            } else {
                randomInitRotation();
                spinBtn.disabled = false;
            }
        }

        function buildLegend() {
            legendContainer.innerHTML = '';
            SEGMENTS.forEach(seg => {
                const item = document.createElement('div');
                item.className = 'legend-item';
                item.innerHTML = `<div class="color-dot" style="background: ${seg.color};"></div><span>${seg.label}</span>`;
                legendContainer.appendChild(item);
            });
        }

        spinBtn.addEventListener('click', requestSpin);
        canvas.addEventListener('click', requestSpin);
        window.addEventListener('keydown', (e) => {
            if (e.code === 'Space' && document.activeElement?.tagName !== 'BUTTON') {
                e.preventDefault();
                requestSpin();
            }
        });

        buildLegend();
        initWheelFromStorage();
        window.addEventListener('resize', () => drawWheel(currentRotation));
    })();
</script>
</body>
</html>